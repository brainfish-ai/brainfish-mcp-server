# Brainfish MCP Server Environment Variables

# Required: Your Brainfish API token (get from https://app.brainfi.sh/settings/api-tokens)
BRAINFISH_API_TOKEN=bf_api_your_token_here

# Optional: Agent key for AI-powered features (get from https://app.brainfi.sh/agents)
BRAINFISH_AGENT_KEY=your_agent_key_here

# Optional: Custom API endpoint (defaults to https://api.brainfi.sh)
# BRAINFISH_API_URL=https://api.brainfi.sh

# Optional: Brainfish web app URL for the MCP setup login button (defaults to https://app.brainfi.sh)
# BRAINFISH_APP_URL=https://app.brainfi.sh

# Optional: Request timeout in milliseconds (defaults to 30000)
# BRAINFISH_TIMEOUT=30000

# Optional: Maximum retry attempts (defaults to 3)
# BRAINFISH_RETRY_ATTEMPTS=3

# Optional: Initial retry delay in milliseconds (defaults to 1000)
# BRAINFISH_RETRY_DELAY=1000